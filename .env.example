# ══════════════════════════════════════════════════════════════
# MOLEBIE AI — ENVIRONMENT CONFIGURATION
# ══════════════════════════════════════════════════════════════
# Single source of truth for gateway and webapp.
# Copy this to .env.local:  cp .env.example .env.local
# Or run: ./install.sh (generates JWT secret automatically)
# ══════════════════════════════════════════════════════════════

# ──────────────────────────────────────────────────────────────
# APPLICATION
# ──────────────────────────────────────────────────────────────
APP_NAME="AI Assistant Gateway"
DEBUG=true

# ──────────────────────────────────────────────────────────────
# ASSISTANT IDENTITY
# ──────────────────────────────────────────────────────────────
# Name used in logs/metadata. Personality is defined in gateway/prompts/
ASSISTANT_NAME=Assistant
PROMPT_DIR=prompts

# ──────────────────────────────────────────────────────────────
# DATA & AUTH
# ──────────────────────────────────────────────────────────────
# SQLite database and local file storage directory
DATA_DIR=data

# "single" = password-only login (default for self-hosted)
# "multi" = email + password signup/login
AUTH_MODE=single

# JWT secret (generated by install.sh — change this!)
JWT_SECRET=CHANGE_ME_TO_A_RANDOM_SECRET
JWT_ALGORITHM=HS256

# ──────────────────────────────────────────────────────────────
# WEBAPP
# ──────────────────────────────────────────────────────────────
# URL the browser uses to reach the Gateway API
# Single-machine: localhost. Multi-machine: this machine's IP.
NEXT_PUBLIC_GATEWAY_URL=http://localhost:8000

# ──────────────────────────────────────────────────────────────
# CORS (origins allowed to call the Gateway API)
# ──────────────────────────────────────────────────────────────
# Comma-separated. Private IPs (192.168.*, 10.*, 172.*) are auto-allowed.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ──────────────────────────────────────────────────────────────
# INFERENCE
# ──────────────────────────────────────────────────────────────
# Works with any OpenAI-compatible server:
#   MLX (Apple Silicon):  make mlx-thinking / make mlx-instant
#   Ollama:               ollama serve         (URL: http://localhost:11434/v1)
#   vLLM:                 vllm serve <model>   (URL: http://localhost:8000/v1)
#   llama.cpp:            llama-server -m model (URL: http://localhost:8080/v1)
#   OpenAI API:           set INFERENCE_API_KEY (URL: https://api.openai.com)

# API key (optional — only needed for commercial backends like OpenAI)
INFERENCE_API_KEY=

# Thinking tier — chain-of-thought reasoning (larger model)
INFERENCE_THINKING_URL=http://localhost:8080
INFERENCE_THINKING_MODEL=mlx-community/Qwen3.5-9B-MLX-4bit
INFERENCE_THINKING_API_PREFIX=
INFERENCE_THINKING_MAX_TOKENS=24576
INFERENCE_THINKING_TEMPERATURE=0.6
INFERENCE_THINKING_TOP_P=0.95
INFERENCE_THINKING_TOP_K=20
INFERENCE_THINKING_TIMEOUT=300.0
INFERENCE_THINKING_ENABLE_THINKING=true
INFERENCE_THINKING_BUDGET=2048
INFERENCE_THINKING_HARDER_MAX_TOKENS=28672
INFERENCE_THINKING_HARDER_BUDGET=8192

# Instant tier — fast responses, voice mode (smaller model)
INFERENCE_INSTANT_URL=http://localhost:8081
INFERENCE_INSTANT_MODEL=mlx-community/Qwen3.5-4B-4bit
INFERENCE_INSTANT_API_PREFIX=
INFERENCE_INSTANT_MAX_TOKENS=2048
INFERENCE_INSTANT_TEMPERATURE=0.7
INFERENCE_INSTANT_TOP_P=0.8
INFERENCE_INSTANT_TOP_K=20
INFERENCE_INSTANT_TIMEOUT=120.0
INFERENCE_INSTANT_ENABLE_THINKING=false

# ──────────────────────────────────────────────────────────────
# Backend-quirk overrides (per tier)
# ──────────────────────────────────────────────────────────────
# JSON object merged into the request payload last (overrides gateway
# defaults). Use this to push backend-specific quirks into config so the
# gateway code stays backend-agnostic. New backend with a new quirk =
# one new line here, no PR.
#
# Canonical use case: mlx_vlm flips its sampler / streaming-buffer paths
# on field PRESENCE, not just value. To keep instant tier on the streaming
# path without enabling CoT, mirror the thinking-tier fields with budget=0:
#
#   INFERENCE_INSTANT_EXTRA_PAYLOAD={"thinking_budget":0,"thinking_start_token":"<think>","thinking_end_token":"</think>"}
#
INFERENCE_INSTANT_EXTRA_PAYLOAD=
INFERENCE_THINKING_EXTRA_PAYLOAD=
INFERENCE_THINKING_HARDER_EXTRA_PAYLOAD=

# ──────────────────────────────────────────────────────────────
# Streaming UX
# ──────────────────────────────────────────────────────────────
# Maximum chars per outbound SSE delta. Larger upstream chunks are split
# into smaller pieces so the frontend typewriter sees a fine-grained stream
# regardless of how the backend chunks (some buffer the whole response).
# 40 ≈ 0.5s at 80 cps (ChatGPT cadence). Set 99999 to disable splitting.
STREAMING_MAX_CHUNK_CHARS=40

# ──────────────────────────────────────────────────────────────
# OPTIONAL SERVICES (require Docker)
# ──────────────────────────────────────────────────────────────
# Start with: docker compose up -d

# Kokoro TTS (text-to-speech)
KOKORO_TTS_URL=http://localhost:8880
KOKORO_TTS_DEFAULT_VOICE=bm_george

# SearXNG (web search — no API key needed)
SEARXNG_URL=http://localhost:8888
WEB_SEARCH_ENABLED=true
WEB_SEARCH_TIMEOUT=5.0
WEB_SEARCH_MAX_RESULTS=5

# ──────────────────────────────────────────────────────────────
# RAG / EMBEDDINGS
# ──────────────────────────────────────────────────────────────
# Defaults live in gateway/app/config.py. Uncomment + change here only
# if you need to override. The Phase-1 hallucination-mitigation work
# moved the defaults to:
#   EMBEDDING_MODEL=Qwen/Qwen3-Embedding-0.6B  (1024-dim, 32K ctx)
#   RAG_MATCH_COUNT=30, RAG_MATCH_THRESHOLD=0.3
#   RAG_MAX_CONTEXT_CHARS=12000
#   RAG_CHUNK_SIZE=512, RAG_CHUNK_OVERLAP=64
# Pre-download the model with:
#   huggingface-cli download Qwen/Qwen3-Embedding-0.6B
#   huggingface-cli download Qwen/Qwen3-Reranker-0.6B
RAG_ENABLED=true

# ──────────────────────────────────────────────────────────────
# FAITHFULNESS JUDGE
# ──────────────────────────────────────────────────────────────
# Cheap post-hoc grounding gate: reuses the Qwen3-Reranker yes/no head
# to score each cited claim against its [S#] chunk. No extra LLM calls
# — one reranker forward pass per claim. Catches off-topic fabrications
# fast; CoVe still handles numeric-substitution attacks within an
# otherwise-relevant chunk.
# Fires only when the response has [S#] citations and is longer than
# JUDGE_MIN_RESPONSE_CHARS. Default ON — ablation showed it doesn't
# hurt pass rate and the cost is near-zero.
JUDGE_ENABLED=true
JUDGE_THRESHOLD=0.5
JUDGE_MIN_RESPONSE_CHARS=200

# ──────────────────────────────────────────────────────────────
# ROUTING
# ──────────────────────────────────────────────────────────────
ROUTING_DEFAULT_MODE=thinking
ROUTING_THINKING_FALLBACK_TO_INSTANT=true
ROUTING_COLD_START_TIMEOUT=60.0

# ──────────────────────────────────────────────────────────────
# COST CONTROLS
# ──────────────────────────────────────────────────────────────
THINKING_DAILY_REQUEST_LIMIT=100
THINKING_MAX_CONCURRENT=2
