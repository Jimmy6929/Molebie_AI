# ══════════════════════════════════════════════════════════════
# MOLEBIE AI — ENVIRONMENT CONFIGURATION
# ══════════════════════════════════════════════════════════════
# Single source of truth for gateway, webapp, and supabase.
# Copy this to .env.local:  cp .env.example .env.local
# Or run: bash setup.sh (fills in Supabase keys automatically)
# ══════════════════════════════════════════════════════════════

# ──────────────────────────────────────────────────────────────
# APPLICATION
# ──────────────────────────────────────────────────────────────
APP_NAME="AI Assistant Gateway"
DEBUG=true

# ──────────────────────────────────────────────────────────────
# ASSISTANT IDENTITY
# ──────────────────────────────────────────────────────────────
# Name used in logs/metadata. Personality is defined in gateway/prompts/
ASSISTANT_NAME=Assistant
PROMPT_DIR=prompts

# ──────────────────────────────────────────────────────────────
# SUPABASE (setup.sh fills these automatically)
# ──────────────────────────────────────────────────────────────
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=YOUR_ANON_KEY_HERE
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY_HERE

# Next.js needs NEXT_PUBLIC_ prefix for client-side access
# Single-machine: use localhost. Multi-machine: use this machine's IP.
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY_HERE

# ──────────────────────────────────────────────────────────────
# WEBAPP
# ──────────────────────────────────────────────────────────────
# URL the browser uses to reach the Gateway API
# Single-machine: localhost. Multi-machine: this machine's IP.
NEXT_PUBLIC_GATEWAY_URL=http://localhost:8000

# ──────────────────────────────────────────────────────────────
# CORS (origins allowed to call the Gateway API)
# ──────────────────────────────────────────────────────────────
# Comma-separated. Private IPs (192.168.*, 10.*, 172.*) are auto-allowed.
# Multi-machine: add your server IP, e.g. http://192.168.1.100:3000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ──────────────────────────────────────────────────────────────
# JWT (setup.sh fills this automatically)
# ──────────────────────────────────────────────────────────────
JWT_SECRET=YOUR_JWT_SECRET_HERE
JWT_ALGORITHM=HS256

# ──────────────────────────────────────────────────────────────
# DATABASE
# ──────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# ──────────────────────────────────────────────────────────────
# INFERENCE
# ──────────────────────────────────────────────────────────────
# Works with any OpenAI-compatible server:
#   MLX (Apple Silicon):  make mlx-thinking / make mlx-instant
#   Ollama:               ollama serve         (URL: http://localhost:11434/v1)
#   vLLM:                 vllm serve <model>   (URL: http://localhost:8000/v1)
#   llama.cpp:            llama-server -m model (URL: http://localhost:8080/v1)
#   OpenAI API:           set INFERENCE_API_KEY (URL: https://api.openai.com)
#
# Single-machine: localhost. Multi-machine: GPU machine's IP.

# API key (optional — only needed for commercial backends like OpenAI)
INFERENCE_API_KEY=

# Thinking tier — chain-of-thought reasoning (larger model)
INFERENCE_THINKING_URL=http://localhost:8080
INFERENCE_THINKING_MODEL=mlx-community/Qwen3.5-9B-4bit
INFERENCE_THINKING_API_PREFIX=
INFERENCE_THINKING_MAX_TOKENS=24576
INFERENCE_THINKING_TEMPERATURE=0.6
INFERENCE_THINKING_TOP_P=0.95
INFERENCE_THINKING_TOP_K=20
INFERENCE_THINKING_TIMEOUT=300.0
INFERENCE_THINKING_ENABLE_THINKING=true
INFERENCE_THINKING_BUDGET=2048
INFERENCE_THINKING_HARDER_MAX_TOKENS=28672
INFERENCE_THINKING_HARDER_BUDGET=8192

# Instant tier — fast responses, voice mode (smaller model)
INFERENCE_INSTANT_URL=http://localhost:8081
INFERENCE_INSTANT_MODEL=mlx-community/Qwen3.5-4B-Instruct-4bit
INFERENCE_INSTANT_API_PREFIX=
INFERENCE_INSTANT_MAX_TOKENS=2048
INFERENCE_INSTANT_TEMPERATURE=0.7
INFERENCE_INSTANT_TOP_P=0.8
INFERENCE_INSTANT_TOP_K=20
INFERENCE_INSTANT_TIMEOUT=120.0
INFERENCE_INSTANT_ENABLE_THINKING=false

# ──────────────────────────────────────────────────────────────
# OPTIONAL SERVICES
# ──────────────────────────────────────────────────────────────
# Start with: docker compose up -d

# Kokoro TTS (text-to-speech)
KOKORO_TTS_URL=http://localhost:8880
KOKORO_TTS_DEFAULT_VOICE=bm_george

# SearXNG (web search — no API key needed)
SEARXNG_URL=http://localhost:8888
WEB_SEARCH_ENABLED=true
WEB_SEARCH_TIMEOUT=5.0
WEB_SEARCH_MAX_RESULTS=5

# ──────────────────────────────────────────────────────────────
# RAG / EMBEDDINGS (auto-downloads on first use)
# ──────────────────────────────────────────────────────────────
RAG_ENABLED=true
EMBEDDING_MODEL=Orange/orange-nomic-v1.5-1536
RAG_MATCH_COUNT=5
RAG_MATCH_THRESHOLD=0.4
RAG_MAX_CONTEXT_CHARS=4000
RAG_CHUNK_SIZE=512
RAG_CHUNK_OVERLAP=50

# ──────────────────────────────────────────────────────────────
# ROUTING
# ──────────────────────────────────────────────────────────────
ROUTING_DEFAULT_MODE=thinking
ROUTING_THINKING_FALLBACK_TO_INSTANT=true
ROUTING_COLD_START_TIMEOUT=60.0

# ──────────────────────────────────────────────────────────────
# COST CONTROLS
# ──────────────────────────────────────────────────────────────
THINKING_DAILY_REQUEST_LIMIT=100
THINKING_MAX_CONCURRENT=2
