<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.jimmy.localai.autopull</string>

    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>/Users/jimmy/Documents/App-project/Local_AI_Project/scripts/auto-pull.sh</string>
    </array>

    <key>StartInterval</key>
    <integer>60</integer>

    <key>ThrottleInterval</key>
    <integer>10</integer>

    <key>WorkingDirectory</key>
    <string>/Users/jimmy/Documents/App-project/Local_AI_Project</string>

    <key>StandardOutPath</key>
    <string>/Users/jimmy/Documents/App-project/Local_AI_Project/logs/auto-pull-stdout.log</string>

    <key>StandardErrorPath</key>
    <string>/Users/jimmy/Documents/App-project/Local_AI_Project/logs/auto-pull-stderr.log</string>

    <key>RunAtLoad</key>
    <true/>

    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/usr/local/bin:/usr/bin:/bin:/opt/homebrew/bin</string>
        <key>HOME</key>
        <string>/Users/jimmy</string>
    </dict>
</dict>
</plist>
