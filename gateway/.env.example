# Gateway Environment Configuration
# Copy this file to .env and fill in your values

# ──────────────────────────────────────────────────────────────
# APPLICATION
# ──────────────────────────────────────────────────────────────
APP_NAME="AI Assistant Gateway"
DEBUG=true

# ──────────────────────────────────────────────────────────────
# SUPABASE
# ──────────────────────────────────────────────────────────────
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ──────────────────────────────────────────────────────────────
# JWT CONFIGURATION
# ──────────────────────────────────────────────────────────────
JWT_SECRET=your_jwt_secret_here
JWT_ALGORITHM=HS256

# ──────────────────────────────────────────────────────────────
# DATABASE
# ──────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# ──────────────────────────────────────────────────────────────
# INFERENCE — TWO-TIER ARCHITECTURE
# ──────────────────────────────────────────────────────────────
# Both tiers use OpenAI-compatible /v1/chat/completions.
# See docs/GPU_SETUP_GUIDE.md for full configuration details.

# ── Instant Tier (fast, always-on, 7B-13B models) ───────────
INFERENCE_INSTANT_URL=http://localhost:11434
INFERENCE_INSTANT_MODEL=mistral:7b-instruct
INFERENCE_INSTANT_MAX_TOKENS=2048
INFERENCE_INSTANT_TEMPERATURE=0.7
INFERENCE_INSTANT_TIMEOUT=120.0

# ── Thinking Tier (stronger, scale-to-zero, 30B-72B models) ─
INFERENCE_THINKING_URL=
INFERENCE_THINKING_MODEL=
INFERENCE_THINKING_MAX_TOKENS=4096
INFERENCE_THINKING_TEMPERATURE=0.5
INFERENCE_THINKING_TIMEOUT=300.0

# ── Legacy / Fallback ────────────────────────────────────────
INFERENCE_MODEL_NAME=default
INFERENCE_MAX_TOKENS=2048
INFERENCE_TEMPERATURE=0.7
INFERENCE_TIMEOUT=120.0
INFERENCE_STREAM=true

# ── Routing ──────────────────────────────────────────────────
ROUTING_DEFAULT_MODE=instant
ROUTING_THINKING_FALLBACK_TO_INSTANT=true
ROUTING_COLD_START_TIMEOUT=60.0

# ── Cost Controls ────────────────────────────────────────────
THINKING_DAILY_REQUEST_LIMIT=100
THINKING_MAX_CONCURRENT=2
