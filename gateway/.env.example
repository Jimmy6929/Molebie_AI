# Gateway Environment Configuration
# Copy this file to .env and fill in your values

# ──────────────────────────────────────────────────────────────
# APPLICATION
# ──────────────────────────────────────────────────────────────
APP_NAME="AI Assistant Gateway"
DEBUG=true

# ──────────────────────────────────────────────────────────────
# SUPABASE
# ──────────────────────────────────────────────────────────────
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ──────────────────────────────────────────────────────────────
# JWT CONFIGURATION
# ──────────────────────────────────────────────────────────────
JWT_SECRET=your_jwt_secret_here
JWT_ALGORITHM=HS256

# ──────────────────────────────────────────────────────────────
# DATABASE
# ──────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# ──────────────────────────────────────────────────────────────
# INFERENCE (MLX-VLM)
# ──────────────────────────────────────────────────────────────
# Thinking tier uses Qwen 3.5 9B via mlx_vlm.server (OpenAI-compatible API).
# Instant tier is reserved for future use.
# See docs/GPU_SETUP_GUIDE.md for full configuration details.

# ── Instant Tier (Voice Conversation: Qwen 3.5 4B) ───────────
# Voice mode in the chat UI always uses this tier. Run mlx_lm.server
# with Qwen 3.5 4B on a separate port, e.g.:
#   mlx_lm.server --host 0.0.0.0 --port 8081 --model mlx-community/Qwen3.5-4B-Instruct-4bit
INFERENCE_INSTANT_URL=http://localhost:8081
INFERENCE_INSTANT_MODEL=mlx-community/Qwen3.5-4B-Instruct-4bit
INFERENCE_INSTANT_API_PREFIX=/v1
INFERENCE_INSTANT_MAX_TOKENS=2048
INFERENCE_INSTANT_TEMPERATURE=0.7
INFERENCE_INSTANT_TIMEOUT=120.0

# ── Thinking Tier (Qwen 3.5 9B via mlx_vlm) ─────────────────
INFERENCE_THINKING_URL=http://localhost:8080
INFERENCE_THINKING_MODEL=mlx-community/Qwen3.5-9B-4bit
INFERENCE_THINKING_API_PREFIX=
INFERENCE_THINKING_MAX_TOKENS=4096
INFERENCE_THINKING_TEMPERATURE=0.5
INFERENCE_THINKING_TIMEOUT=300.0

# ── Kokoro TTS (local text-to-speech) ─────────────────────
# Run: docker run -p 8880:8880 ghcr.io/remsky/kokoro-fastapi-cpu:latest
KOKORO_TTS_URL=http://localhost:8880
KOKORO_TTS_DEFAULT_VOICE=bm_george

# ── Legacy / Fallback ────────────────────────────────────────
INFERENCE_MODEL_NAME=default
INFERENCE_MAX_TOKENS=2048
INFERENCE_TEMPERATURE=0.7
INFERENCE_TIMEOUT=120.0
INFERENCE_STREAM=true

# ── Routing ──────────────────────────────────────────────────
ROUTING_DEFAULT_MODE=thinking
ROUTING_THINKING_FALLBACK_TO_INSTANT=true
ROUTING_COLD_START_TIMEOUT=60.0

# ── Cost Controls ────────────────────────────────────────────
THINKING_DAILY_REQUEST_LIMIT=100
THINKING_MAX_CONCURRENT=2
